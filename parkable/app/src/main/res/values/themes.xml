<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Parkable" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.Parkable.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/parkable_blue_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/parkable_blue_primary</item>
        <item name="postSplashScreenTheme">@style/Theme.Parkable</item>
    </style>
</resources>
